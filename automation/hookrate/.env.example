# Copy this file to .env and fill in real values for local testing.
# Never commit the real .env — it's already in .gitignore.

# --- Required ---

# Notion internal integration token (from https://www.notion.so/my-integrations)
NOTION_TOKEN=

# Target Notion database id — the 32 hex chars in the database URL
NOTION_DATABASE_ID=

# Long-lived Meta System User access token with ads_read scope
META_ACCESS_TOKEN=

# Meta ad account id. The "act_" prefix is added automatically if omitted.
META_AD_ACCOUNT_ID=

# --- Optional tuning (defaults shown) ---

# Minimum lifetime spend (GBP) before a row is processed
SPEND_THRESHOLD_GBP=100

# Compute + log intended writes without touching Notion
DRY_RUN=true

# Re-process rows already marked Synced
FORCE_REPROCESS=false

# Meta insights window: "maximum" = lifetime, or e.g. "last_30d"
META_DATE_PRESET=maximum

# Country used for Ad Library search + fallback link
AD_LIBRARY_COUNTRY=GB

# Also write spend into a "Spend" column if present
WRITE_SPEND=false

# Make the run fail (non-zero exit) if any row errored
FAIL_ON_ERROR=false

# Notion column name overrides — only needed if your board uses different names
PROP_HOOK_RATE=Hook Rate
PROP_AD_LIBRARY=Ad Link
PROP_STATUS=Sync Status
PROP_SPEND=Spend

# Property holding the value to match against the Meta ad name. Supports title,
# rich_text, select, and formula (string/number/boolean) column types. Falls
# back to the page's actual Title if this property is missing or empty.
PROP_AD_NAME=Ad Name

# Only process the one Notion row whose match name (see PROP_AD_NAME above)
# exactly matches this (case/whitespace insensitive). Leave blank for normal
# full-board runs. Handy for testing a single ad before trusting the sync
# against the whole board.
TEST_AD_NAME=
